          "title": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "category": {
            "type": "string",
            "nullable": true
          },
          "condition": {
            "type": "string",
            "nullable": true
          },
          "startingBid": {
            "type": "number",
            "format": "double"
          },
          "minimumIncrement": {
            "type": "number",
            "format": "double"
          },
          "buyNowPrice": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "pickupLocation": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PlaceBidRequest": {
        "type": "object",
        "properties": {
