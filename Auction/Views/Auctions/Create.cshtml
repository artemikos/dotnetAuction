@{
    ViewData["Title"] = "New Listing";
    Layout = "_Layout";
}

<style>
    .section-card {
        background: white;
        border-radius: 1rem;
        padding: 1.25rem;
        margin-bottom: 1rem;
        box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .step-dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 50%;
        background: #bbf7d0;
        transition: background 0.2s;
    }
    .step-dot.active { background: #16a34a; }
</style>

<div class="flex justify-center gap-2 py-3 bg-white border-b border-swamp-50">
    <div class="step-dot active"></div>
    <div class="step-dot active"></div>
    <div class="step-dot"></div>
    <div class="step-dot"></div>
</div>

<div class="max-w-2xl mx-auto px-4 pt-4">
    <div class="section-card">
        <h2 class="text-base font-bold text-swamp-900 mb-3">Item Details</h2>
        <div class="space-y-3">
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Title *</label>
                <input id="Title" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" required>
            </div>
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Description *</label>
                <textarea id="Description" rows="4" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" required></textarea>
            </div>
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Category *</label>
                <select id="Category" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" required>
                    <option value="">Select...</option>
                    <option value="Tech">Tech</option>
                    <option value="Books">Books</option>
                    <option value="Furniture">Furniture</option>
                    <option value="Clothing">Clothing</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Condition *</label>
                <select id="Condition" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" required>
                    <option value="New">New</option>
                    <option value="Like New">Like New</option>
                    <option value="Good" selected>Good</option>
                    <option value="Fair">Fair</option>
                </select>
            </div>
        </div>
    </div>

    <div class="section-card">
        <h2 class="text-base font-bold text-swamp-900 mb-3">Pricing</h2>
        <div class="grid grid-cols-2 gap-3">
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Starting bid ($) *</label>
                <input id="StartingBid" type="number" min="1" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" required>
            </div>
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Min. increment ($) *</label>
                <input id="MinimumIncrement" type="number" min="1" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" required>
            </div>
        </div>
        <div class="mt-3">
            <label class="block text-xs font-semibold text-swamp-700 mb-1">Buy Now price ($)</label>
            <input id="BuyNowPrice" type="number" min="1" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm">
        </div>
    </div>

    <div class="section-card">
        <h2 class="text-base font-bold text-swamp-900 mb-3">Logistics</h2>
        <div class="space-y-3">
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Auction ends at *</label>
                <input id="EndTime" type="datetime-local" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" required>
            </div>
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Pickup location *</label>
                <input id="PickupLocation" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" required>
            </div>
        </div>
    </div>

    <div class="bg-swamp-50 border border-swamp-200 rounded-xl p-3 mb-4">
        <p class="text-xs text-swamp-700">Once a bid is placed you can't cancel this listing.</p>
    </div>

    <button onclick="createAuction()" class="w-full bg-swamp-500 text-white py-3 rounded-full font-semibold text-sm mb-6">
        Post Listing 🐸
    </button>
</div>

@section Scripts {
    <script>
        async function createAuction() {
            const token = localStorage.getItem('token');
            if (!token) { openAuthModal(); return; }

            const res = await fetch('/api/auctions', {
                method: 'POST',
                headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    title:            document.getElementById('Title').value,
                    description:      document.getElementById('Description').value,
                    category:         document.getElementById('Category').value,
                    condition:        document.getElementById('Condition').value,
                    startingBid:      parseFloat(document.getElementById('StartingBid').value),
                    minimumIncrement: parseFloat(document.getElementById('MinimumIncrement').value),
                    buyNowPrice:      document.getElementById('BuyNowPrice').value
                                      ? parseFloat(document.getElementById('BuyNowPrice').value)
                                      : null,
                    endTime:          new Date(document.getElementById('EndTime').value).toISOString(),
                    pickupLocation:   document.getElementById('PickupLocation').value
                })
            });

            if (res.ok) {
                const auction = await res.json();
                window.location.href = '/auctions/detail/' + auction.id;
            } else {
                alert((await res.json()).message);
            }
        }
    </script>
}
