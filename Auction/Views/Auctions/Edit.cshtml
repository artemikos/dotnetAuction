@model Auction.DTOs.AuctionDetailDto
@{
    ViewData["Title"] = "Edit Listing";
    Layout = "_Layout";
}

<div class="max-w-2xl mx-auto px-4 py-4">
    <a href="/auctions/detail/@Model.Id" class="text-sm text-swamp-600 mb-3 inline-block">← Back</a>

    <div class="bg-white rounded-2xl p-4 mb-3 shadow-sm">
        <h2 class="text-base font-bold mb-3">Item Details</h2>
        <div class="space-y-3">
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Title *</label>
                <input id="Title" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" value="@Model.Title" required>
            </div>
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Description *</label>
                <textarea id="Description" rows="3" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" required>@Model.Description</textarea>
            </div>
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Category *</label>
                <select id="Category" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" required>
                    <option value="Tech"      selected="@(Model.Category == "Tech")">Tech</option>
                    <option value="Books"     selected="@(Model.Category == "Books")">Books</option>
                    <option value="Furniture" selected="@(Model.Category == "Furniture")">Furniture</option>
                    <option value="Clothing"  selected="@(Model.Category == "Clothing")">Clothing</option>
                    <option value="Other"     selected="@(Model.Category == "Other")">Other</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Condition *</label>
                <select id="Condition" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" required>
                    <option value="New"      selected="@(Model.Condition == "New")">New</option>
                    <option value="Like New" selected="@(Model.Condition == "Like New")">Like New</option>
                    <option value="Good"     selected="@(Model.Condition == "Good")">Good</option>
                    <option value="Fair"     selected="@(Model.Condition == "Fair")">Fair</option>
                </select>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl p-4 mb-3 shadow-sm">
        <h2 class="text-base font-bold mb-3">Pricing</h2>
        <div class="grid grid-cols-2 gap-3">
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Starting Bid ($) *</label>
                <input id="StartingBid" type="number" min="1" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" value="@Model.StartingBid" required>
            </div>
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Min Increment ($) *</label>
                <input id="MinimumIncrement" type="number" min="1" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" value="@Model.MinimumIncrement" required>
            </div>
        </div>
        <div class="mt-3">
            <label class="block text-xs font-semibold text-swamp-700 mb-1">Buy Now Price (optional)</label>
            <input id="BuyNowPrice" type="number" min="1" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" value="@Model.BuyNowPrice">
        </div>
    </div>

    <div class="bg-white rounded-2xl p-4 mb-3 shadow-sm">
        <h2 class="text-base font-bold mb-3">Logistics</h2>
        <div class="space-y-3">
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">End Time *</label>
                <input id="EndTime" type="datetime-local"
                       class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm"
                       value="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm")" required>
            </div>
            <div>
                <label class="block text-xs font-semibold text-swamp-700 mb-1">Pickup Location *</label>
                <input id="PickupLocation" class="w-full border-2 border-swamp-200 rounded-xl px-3 py-2 text-sm" value="@Model.PickupLocation" required>
            </div>
        </div>
    </div>

    <button onclick="saveChanges()" class="w-full bg-swamp-500 text-white py-3 rounded-full font-semibold text-sm mb-6">
        Save Changes
    </button>
</div>

@section Scripts {
    <script>
        async function saveChanges() {
            const token = localStorage.getItem('token');
            if (!token) { openAuthModal(); return; }

            const res = await fetch('/api/auctions/@Model.Id', {
                method: 'PUT',
                headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    title:            document.getElementById('Title').value,
                    description:      document.getElementById('Description').value,
                    category:         document.getElementById('Category').value,
                    condition:        document.getElementById('Condition').value,
                    startingBid:      parseFloat(document.getElementById('StartingBid').value),
                    minimumIncrement: parseFloat(document.getElementById('MinimumIncrement').value),
                    buyNowPrice:      document.getElementById('BuyNowPrice').value
                                      ? parseFloat(document.getElementById('BuyNowPrice').value)
                                      : null,
                    endTime:          new Date(document.getElementById('EndTime').value).toISOString(),
                    pickupLocation:   document.getElementById('PickupLocation').value
                })
            });

            if (res.ok) window.location.href = '/auctions/detail/@Model.Id';
            else alert((await res.json()).message);
        }
    </script>
}
